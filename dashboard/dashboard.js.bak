п»ҝ// LinguaFlow Dashboard
// Gerencia SRS, vocabulГғВЎrio, estatГғВӯsticas e configuraГғВ§ГғВөes

// ============================================================
// UTILITГғВҒRIOS
// ============================================================

const DB_NAME = 'LinguaFlowFreeDB';
const DB_VERSION = 3;

async function openDB() {
    return new Promise((resolve, reject) => {
        const request = indexedDB.open(DB_NAME, DB_VERSION);
        
        request.onupgradeneeded = (e) => {
            const db = e.target.result;
            
            if (!db.objectStoreNames.contains('words')) {
                const store = db.createObjectStore('words', { keyPath: 'id', autoIncrement: true });
                store.createIndex('word_lang', ['word', 'lang'], { unique: true });
                store.createIndex('deck_id', 'deck_id', { unique: false });
            }
            
            if (!db.objectStoreNames.contains('cards')) {
                const store = db.createObjectStore('cards', { keyPath: 'id', autoIncrement: true });
                store.createIndex('word_id', 'word_id', { unique: true });
                store.createIndex('due_date', 'due_date', { unique: false });
                store.createIndex('status', 'status', { unique: false });
            }
            
            if (!db.objectStoreNames.contains('decks')) {
                db.createObjectStore('decks', { keyPath: 'id', autoIncrement: true });
            }
            
            if (!db.objectStoreNames.contains('known_words')) {
                db.createObjectStore('known_words', { keyPath: ['word', 'lang'] });
            }
            
            if (!db.objectStoreNames.contains('sessions')) {
                db.createObjectStore('sessions', { keyPath: 'date' });
            }
            
            if (!db.objectStoreNames.contains('settings')) {
                db.createObjectStore('settings', { keyPath: 'key' });
            }
        };
        
        request.onsuccess = (e) => resolve(e.target.result);
        request.onerror = () => reject(request.error);
    });
}

// ============================================================
// SRS ENGINE (SuperMemo-2)
// ============================================================

const SRS_DEFAULTS = {
    newPerDay: 20,
    reviewsPerDay: 100,
    learningSteps: [1, 10],
    graduatingInterval: 1,
    easyInterval: 4,
    startingEase: 2.5,
    easyBonus: 1.3,
    intervalModifier: 1.0,
    lapseSteps: [10],
    minInterval: 1,
    lapsePenalty: 0.2,
    newOrder: 'added',
    showIPA: true,
    showContext: true,
    autoAudio: false,
    nativeLang: 'pt',
    targetLang: 'en'
};

async function loadSettings() {
    try {
        const db = await openDB();
        const tx = db.transaction(['settings'], 'readonly');
        const store = tx.objectStore('settings');
        const req = store.getAll();
        
        return new Promise((resolve, reject) => {
            req.onsuccess = () => {
                const settings = {};
                req.result.forEach(item => {
                    settings[item.key] = item.value;
                });
                resolve({ ...SRS_DEFAULTS, ...settings });
            };
            req.onerror = () => reject(req.error);
        });
    } catch (e) {
        console.error('Erro ao carregar settings:', e);
        return SRS_DEFAULTS;
    }
}

async function saveSettings(settings) {
    const db = await openDB();
    const tx = db.transaction(['settings'], 'readwrite');
    const store = tx.objectStore('settings');
    
    Object.entries(settings).forEach(([key, value]) => {
        store.put({ key, value });
    });
    
    return new Promise((resolve, reject) => {
        tx.oncomplete = () => resolve();
        tx.onerror = () => reject(tx.error);
    });
}

async function resetSettings() {
    const db = await openDB();
    const tx = db.transaction(['settings'], 'readwrite');
    const store = tx.objectStore('settings');
    
    // Remove todos os settings
    store.clear();
    
    return new Promise((resolve, reject) => {
        tx.oncomplete = () => resolve();
        tx.onerror = () => reject(tx.error);
    });
}

// Algoritmo SuperMemo-2
function calculateNextInterval(card, quality) {
    // quality: 0=Erro, 1=DifГғВӯcil, 2=Bom, 3=FГғВЎcil
    const ease = card.ease_factor;
    const interval = card.interval;
    
    let newInterval;
    if (quality === 0) {
        newInterval = 1;
    } else if (quality === 1) {
        newInterval = Math.round(interval * 1.2);
    } else if (quality === 2) {
        newInterval = Math.round(interval * ease);
    } else {
        newInterval = Math.round(interval * ease * 1.3);
    }
    
    return Math.max(1, newInterval);
}

function updateCard(card, quality) {
    // quality: 0=Erro, 1=DifГғВӯcil, 2=Bom, 3=FГғВЎcil
    const newInterval = calculateNextInterval(card, quality);
    const newEase = Math.max(1.3, card.ease_factor + (0.1 - (5 - quality) * (0.08 + (5 - quality) * 0.02)));
    
    let newStatus;
    if (card.status === 'new') {
        newStatus = quality >= 2 ? 'learning' : 'learning';
    } else if (card.status === 'learning') {
        newStatus = newInterval >= 21 ? 'mature' : 'review';
    } else if (card.status === 'review') {
        newStatus = newInterval >= 21 ? 'mature' : 'review';
    } else {
        newStatus = 'mature';
    }
    
    return {
        ...card,
        interval: newInterval,
        ease_factor: newEase,
        reps: card.reps + 1,
        lapses: quality === 0 ? card.lapses + 1 : card.lapses,
        due_date: Date.now() + newInterval * 24 * 60 * 60 * 1000,
        status: newStatus
    };
}

// ============================================================
// DASHBOARD CORE
// ============================================================

class Dashboard {
    constructor() {
        this.currentTab = 'review';
        this.words = [];
        this.cards = [];
        this.settings = SRS_DEFAULTS;
        this.currentCard = null;
        this.revealMode = false;
        this.init();
    }
    
    async init() {
        this.settings = await loadSettings();
        this.setupUI();
        this.loadStats();
        this.loadReview();
        this.setupEventListeners();
    }
    
    setupUI() {
        // Atualiza badge de status
        document.getElementById('sf-total').textContent = '0';
        document.getElementById('sf-due').textContent = '0';
        
        // Atualiza estatГғВӯsticas
        document.getElementById('stat-total').textContent = '0';
        document.getElementById('stat-due').textContent = '0';
        document.getElementById('stat-new').textContent = '0';
        document.getElementById('stat-learned').textContent = '0';
        document.getElementById('stat-learning').textContent = '0';
        document.getElementById('stat-mature').textContent = '0';
    }
    
    async loadStats() {
        try {
            const db = await openDB();
            const tx = db.transaction(['words', 'cards'], 'readonly');
            const wordsStore = tx.objectStore('words');
            const cardsStore = tx.objectStore('cards');
            
            // Conta palavras
            const wordsReq = wordsStore.count();
            const cardsReq = cardsStore.count();
            
            // Conta por status
            const index = cardsStore.index('status');
            const statusCounts = {};
            
            return new Promise((resolve) => {
                wordsReq.onsuccess = () => {
                    statusCounts.total = wordsReq.result;
                    document.getElementById('stat-total').textContent = statusCounts.total;
                    document.getElementById('sf-total').textContent = statusCounts.total;
                };
                
                cardsReq.onsuccess = () => {
                    statusCounts.cards = cardsReq.result;
                    
                    // Conta due today
                    const today = new Date();
                    today.setHours(0, 0, 0, 0);
                    const dueReq = index.openCursor(IDBKeyRange.upperBound(today.getTime()));
                    
                    let dueCount = 0;
                    dueReq.onsuccess = () => {
                        const cursor = dueReq.result;
                        if (cursor) {
                            dueCount++;
                            cursor.continue();
                        } else {
                            statusCounts.due = dueCount;
                            document.getElementById('stat-due').textContent = dueCount;
                            document.getElementById('sf-due').textContent = dueCount;
                            
                            // Conta por status
                            const allCardsReq = cardsStore.getAll();
                            allCardsReq.onsuccess = () => {
                                allCardsReq.result.forEach(card => {
                                    statusCounts[card.status] = (statusCounts[card.status] || 0) + 1;
                                });
                                
                                document.getElementById('stat-new').textContent = statusCounts.new || 0;
                                document.getElementById('stat-learning').textContent = statusCounts.learning || 0;
                                if (document.getElementById('stat-review')) document.getElementById('stat-review').textContent = statusCounts.review || 0;
                                document.getElementById('stat-mature').textContent = statusCounts.mature || 0;
                                
                                resolve(statusCounts);
                            };
                        }
                    };
                };
            });
        } catch (e) {
            console.error('Erro ao carregar stats:', e);
            return { total: 0, due: 0, new: 0, learning: 0, review: 0, mature: 0 };
        }
    }
    
    async loadReview() {
        try {
            const db = await openDB();
            const tx = db.transaction(['cards', 'words'], 'readonly');
            const cardsStore = tx.objectStore('cards');
            const wordsStore = tx.objectStore('words');
            
            // Busca cards devidos hoje
            const today = new Date();
            today.setHours(0, 0, 0, 0);
            const dueDate = today.getTime();
            
            const index = cardsStore.index('due_date');
            const cursorReq = index.openCursor(IDBKeyRange.lowerBound(dueDate));
            
            const dueCards = [];
            
            return new Promise((resolve) => {
                cursorReq.onsuccess = () => {
                    const cursor = cursorReq.result;
                    if (cursor) {
                        dueCards.push(cursor.value);
                        cursor.continue();
                    } else {
                        if (dueCards.length === 0) {
                            this.showEmptyReview();
                            resolve();
                            return;
                        }
                        
                        // Carrega palavras associadas
                        const wordPromises = dueCards.map(card => {
                            return new Promise((resolveWord) => {
                                const wordReq = wordsStore.get(card.word_id);
                                wordReq.onsuccess = () => {
                                    resolveWord({ ...card, wordData: wordReq.result });
                                };
                                wordReq.onerror = () => resolveWord(card);
                            });
                        });
                        
                        Promise.all(wordPromises).then(cardsWithWords => {
                            this.cards = cardsWithWords;
                            this.currentCardIndex = 0;
                            this.renderCard();
                            resolve();
                        });
                    }
                };
                cursorReq.onerror = () => {
                    this.showEmptyReview();
                    resolve();
                };
            });
        } catch (e) {
            console.error('Erro ao carregar review:', e);
            this.showEmptyReview();
        }
    }
    
    showEmptyReview() {
        document.getElementById('empty-msg').style.display = 'block';
        document.getElementById('flashcard-container').style.display = 'none';
    }
    
    renderCard() {
        if (this.currentCardIndex >= this.cards.length) {
            this.showEmptyReview();
            return;
        }
        
        this.currentCard = this.cards[this.currentCardIndex];
        this.revealMode = false;
        
        const card = this.currentCard;
        const word = card.wordData;
        
        // Atualiza progresso
        const progress = `${this.currentCardIndex + 1} / ${this.cards.length}`;
        document.getElementById('progress-text').textContent = progress;
        document.getElementById('progress-fill').style.width = `${((this.currentCardIndex + 1) / this.cards.length) * 100}%`;
        
        // Atualiza badges
        document.getElementById('badge-cefr').textContent = word.cefr_guess || 'A1';
        document.getElementById('badge-status').textContent = card.status.toUpperCase();
        
        // Atualiza conteГғВәdo
        document.getElementById('card-word').textContent = word.word || 'ГўвӮ¬вҖқ';
        document.getElementById('card-ipa').textContent = word.ipa ? `/${word.ipa}/` : '';
        document.getElementById('card-context').textContent = word.context_sentence || '';
        document.getElementById('card-translation').textContent = word.translation || 'ГўвӮ¬вҖқ';
        
        // Atualiza detalhes
        const details = [];
        if (word.part_of_speech) details.push(`Parte da fala: ${word.part_of_speech}`);
        if (word.frequency_rank) details.push(`FrequГғВӘncia: ${word.frequency_rank}`);
        if (word.added_at) details.push(`Adicionado: ${new Date(word.added_at).toLocaleDateString()}`);
        
        document.getElementById('card-details').innerHTML = details.map(d => `<p>${d}</p>`).join('');
        
        // Mostra/oculta back
        document.getElementById('card-back').style.display = 'none';
        document.getElementById('btn-reveal').style.display = 'block';
        document.getElementById('btn-grades').style.display = 'none';
        
        // Atualiza intervalos previstos
        this.updateIntervalPredictions(card);
    }
    
    updateIntervalPredictions(card) {
        // Calcula intervalos previstos para cada qualidade
        const qualities = [1, 2, 3, 4];
        const ease = card.ease_factor || 2.5;
        const interval = card.interval;
        
        qualities.forEach(q => {
            let newInterval;
            if (q === 1) {
                newInterval = 1;
            } else if (q === 2) {
                newInterval = Math.round(interval * 1.2);
            } else if (q === 3) {
                newInterval = Math.round(interval * ease);
            } else {
                newInterval = Math.round(interval * ease * 1.3);
            }
            
            const btn = document.querySelector(`.btn-grade[data-q="${q}"]`);
            if (btn) {
                btn.querySelector('small').textContent = `${newInterval}d`;
            }
        });
    }
    
    revealAnswer() {
        this.revealMode = true;
        document.getElementById('card-back').style.display = 'block';
        document.getElementById('btn-reveal').style.display = 'none';
        document.getElementById('btn-grades').style.display = 'flex';
        
        // Auto-reproduz ГғВЎudio se configurado
        if (this.settings.autoAudio && this.currentCard.wordData.word) {
            // Usa o TTS melhorado para reproduzir a palavra
            this.speakText(this.currentCard.wordData.word, 'en-US');
        }
    }
    
    gradeCard(quality) {
        if (!this.currentCard) return;
        
        const newCard = updateCard(this.currentCard, quality);
        
        // Salva card atualizado
        this.updateCardInDB(newCard);
        
        // AvanГғВ§a para prГғВіximo card
        this.currentCardIndex++;
        
        if (this.currentCardIndex >= this.cards.length) {
            this.showEmptyReview();
        } else {
            this.renderCard();
        }
    }
    
    async updateCardInDB(card) {
        try {
            const db = await openDB();
            const tx = db.transaction(['cards'], 'readwrite');
            const store = tx.objectStore('cards');
            
            store.put(card);
            
            return new Promise((resolve, reject) => {
                tx.oncomplete = () => resolve();
                tx.onerror = () => reject(tx.error);
            });
        } catch (e) {
            console.error('Erro ao atualizar card:', e);
        }
    }
    
    async playAudio(url) {
        try {
            // Importa o TTS melhorado
            const { tts } = await import('../utils/tts.js');
            
            // Se tem URL de ГғВЎudio do dicionГғВЎrio, usa ela
            if (url) {
                await tts.play('', 'en-US', url);
            }
        } catch (e) {
            console.error('[LinguaFlow Dashboard] Erro ao reproduzir ГғВЎudio:', e);
        }
    }
    
    async speakText(text, lang = null) {
        try {
            const { tts } = await import('../utils/tts.js');
            const targetLang = lang || this.settings.targetLang || 'en-US';
            await tts.play(text, targetLang);
        } catch (e) {
            console.error('[LinguaFlow Dashboard] Erro ao falar texto:', e);
        }
    }

    setupEventListeners() {
        // NavegaГғВ§ГғВЈo
        document.querySelectorAll('.nav-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const tab = e.target.dataset.tab;
                this.switchTab(tab);
            });
        });
        
        // BotГғВЈo revelar
        document.getElementById('btn-reveal').addEventListener('click', () => this.revealAnswer());
        
        // BotГғВөes de graduaГғВ§ГғВЈo
        document.querySelectorAll('.btn-grade').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const quality = parseInt(e.target.dataset.q);
                this.gradeCard(quality);
            });
        });
        
        // BotГғВЈo verificar novamente
        document.getElementById('btn-reveal').addEventListener('click', () => this.loadReview());
        
        // BotГғВөes de vocabulГғВЎrio
        document.getElementById('vocab-search').addEventListener('input', (e) => this.filterVocab(e.target.value));
        
        // BotГғВөes de settings
        document.getElementById('btn-save-settings').addEventListener('click', () => this.saveSettings());
        document.getElementById('btn-reset-settings').addEventListener('click', () => this.resetSettings());
        
        // BotГғВөes de export/import
        document.getElementById('btn-export-all').addEventListener('click', () => this.exportData());
        document.getElementById('btn-import-all').addEventListener('click', () => this.importData());
        document.getElementById('btn-export-anki').addEventListener('click', () => this.exportToAnki());
        
        // BotГғВЈo de import file
        document.getElementById('import-file-input').addEventListener('change', (e) => this.handleImportFile(e));
        
        // BotГғВЈo de ir para vГғВӯdeo
        document.getElementById('btn-goto-video').addEventListener('click', () => {
            if (this.currentCard && this.currentCard.wordData.video_url) {
                window.open(this.currentCard.wordData.video_url, '_blank');
            }
        });
        
        // BotГғВЈo de atualizar dashboard
        document.getElementById('btn-refresh-dashboard').addEventListener('click', () => {
            console.log('[LinguaFlow Dashboard] AtualizaГғВ§ГғВЈo manual solicitada');
            this.loadVocab();
            this.loadStats();
            this.loadReview();
            alert('Dashboard atualizado!');
        });
        
        // BotГғВөes TTS
        document.getElementById('btn-tts-word').addEventListener('click', () => {
            if (this.currentCard && this.currentCard.wordData.word) {
                this.speakText(this.currentCard.wordData.word, 'en-US');
            }
        });
        
        document.getElementById('btn-tts-sentence').addEventListener('click', () => {
            if (this.currentCard && this.currentCard.wordData.context_sentence) {
                this.speakText(this.currentCard.wordData.context_sentence, 'en-US');
            }
        });
    } // fim setupEventListeners
    
    switchTab(tab) {
        this.currentTab = tab;
        
        // Atualiza botГғВөes
        document.querySelectorAll('.nav-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.tab === tab);
        });
        
        // Atualiza conteГғВәdo
        document.querySelectorAll('.tab-content').forEach(content => {
            content.classList.toggle('active', content.id === `tab-${tab}`);
        });
        
        // Carrega conteГғВәdo especГғВӯfico
        if (tab === 'vocab') this.loadVocab();
        if (tab === 'stats') this.loadStats();
        if (tab === 'settings') this.loadSettingsUI();
    }
    
    async loadVocab() {
        console.log('[LinguaFlow Dashboard] Carregando vocabulГғВЎrio...');
        try {
            const db = await openDB();
            const tx = db.transaction(['words'], 'readonly');
            const store = tx.objectStore('words');
            
            const req = store.getAll();
            
            return new Promise((resolve) => {
                req.onsuccess = () => {
                    console.log('[LinguaFlow Dashboard] Palavras carregadas:', req.result.length);
                    this.words = req.result;
                    this.renderVocab();
                    resolve();
                };
                req.onerror = (error) => {
                    console.error('[LinguaFlow Dashboard] Erro ao carregar palavras:', error);
                    this.words = [];
                    this.renderVocab();
                    resolve();
                };
            });
        } catch (e) {
            console.error('[LinguaFlow Dashboard] Erro ao carregar vocabulГғВЎrio:', e);
            this.words = [];
            this.renderVocab();
        }
    }
    
    renderVocab() {
        console.log('[LinguaFlow Dashboard] Renderizando vocabulГғВЎrio...');
        const tbody = document.getElementById('vocab-tbody');
        const search = document.getElementById('vocab-search').value.toLowerCase();
        const filter = document.getElementById('vocab-filter').value;
        
        console.log('[LinguaFlow Dashboard] Total de palavras:', this.words.length);
        console.log('[LinguaFlow Dashboard] Filtro:', filter);
        console.log('[LinguaFlow Dashboard] Busca:', search);
        
        let filtered = this.words.filter(word => {
            const matchesSearch = word.word.toLowerCase().includes(search);
            const matchesFilter = filter === 'all' || word.status === filter;
            return matchesSearch && matchesFilter;
        });
        
        console.log('[LinguaFlow Dashboard] Palavras filtradas:', filtered.length);
        
        document.getElementById('vocab-count').textContent = `${filtered.length} palavras`;
        
        if (filtered.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:#94A3B8;">Nenhuma palavra encontrada</td></tr>';
            return;
        }
        
        tbody.innerHTML = filtered.map(word => `
            <tr>
                <td class="word-cell" onclick="dashboard.showWordModal(${word.id})">${word.word}</td>
                <td>${word.translation || '-'}</td>
                <td>${word.cefr_guess || '-'}</td>
                <td><span class="status-badge status-${word.status || 'new'}">${word.status || 'new'}</span></td>
                <td>${word.platform || 'manual'}</td>
                <td>${word.added_at ? new Date(word.added_at).toLocaleDateString() : '-'}</td>
                <td>
                    <button class="btn-action" style="padding:4px 8px;font-size:11px;" onclick="dashboard.deleteWord(${word.id})">Г°ЕёвҖ”вҖҳГҜВёВҸ</button>
                </td>
            </tr>
        `).join('');
        
        console.log('[LinguaFlow Dashboard] VocabulГғВЎrio renderizado com sucesso');
    }
    
    filterVocab(search) {
        this.renderVocab();
    }
    
    async showWordModal(wordId) {
        try {
            const db = await openDB();
            const tx = db.transaction(['words'], 'readonly');
            const store = tx.objectStore('words');
            
            const wordReq = store.get(wordId);
            
            return new Promise((resolve) => {
                wordReq.onsuccess = () => {
                    const word = wordReq.result;
                    if (word) {
                        this.renderWordModal(word);
                    }
                    resolve();
                };
                wordReq.onerror = () => resolve();
            });
        } catch (e) {
            console.error('Erro ao carregar palavra:', e);
        }
    }
    
    renderWordModal(word) {
        const modal = document.getElementById('word-modal');
        
        // Atualiza header
        document.getElementById('modal-word').textContent = word.word;
        document.getElementById('modal-ipa').textContent = word.ipa ? `/${word.ipa}/` : '';
        document.getElementById('modal-translation').textContent = word.translation || '';
        document.getElementById('modal-context').textContent = word.context_sentence || '';
        
        // Atualiza word types
        const wordTypes = document.getElementById('modal-word-types');
        if (word.part_of_speech) {
            wordTypes.innerHTML = `
                <div class="lf-word-type">
                    <span class="pos-label">(${word.part_of_speech})</span>
                    <span class="pos-trans">${word.translation}</span>
                </div>
            `;
        }
        
        // BotГғВЈo de ГғВЎudio
        document.getElementById('modal-btn-audio').onclick = () => {
            this.speakText(word.word, 'en-US');
        };
        
        // BotГғВЈo de vГғВӯdeo
        document.getElementById('modal-btn-video').onclick = () => {
            if (word.video_url) {
                const timestamp = word.timestamp || 0;
                const url = `${word.video_url}&t=${Math.floor(timestamp)}`;
                window.open(url, '_blank');
            }
        };
        
        // BotГғВЈo fechar
        document.getElementById('modal-close').onclick = () => {
            modal.style.display = 'none';
        };
        
        // Carrega conteГғВәdo das abas
        this.loadModalExplicar(word);
        this.loadModalExemplos(word.word);
        this.loadModalGramatica(word);
        this.loadModalLinguee(word.word);
        
        // Inicializa abas do modal
        this.initModalTabs();
        
        // Mostra modal
        modal.style.display = 'flex';
    }
    
    initModalTabs() {
        document.querySelectorAll('.modal-tab').forEach(tab => {
            tab.addEventListener('click', (e) => {
                const tabName = e.target.dataset.tab;
                
                // Atualiza abas ativas
                document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.modal-panel').forEach(p => p.classList.remove('active'));
                
                e.target.classList.add('active');
                document.querySelector(`[data-panel="${tabName}"]`).classList.add('active');
            });
        });
    }
    
    loadModalExplicar(word) {
        const panel = document.getElementById('panel-explicar');
        
        let html = `<strong>${word.part_of_speech?.toUpperCase() || 'PALAVRA'}</strong><br><br>`;
        html += `<p>${word.translation || 'TraduГғВ§ГғВЈo nГғВЈo disponГғВӯvel'}</p>`;
        
        panel.innerHTML = html;
    }
    
    async loadModalExemplos(word) {
        const panel = document.getElementById('panel-exemplos');
        panel.innerHTML = '<div class="loading-text">Buscando exemplos do Linguee...</div>';
        
        try {
            const response = await chrome.runtime.sendMessage({
                type: 'FETCH_LINGUEE',
                word: word
            });
            
            if (!response || !response.success) {
                throw new Error('Falha ao buscar exemplos');
            }
            
            const parser = new DOMParser();
            const doc = parser.parseFromString(response.html, 'text/html');
            
            // Extrai exemplos VERIFICADOS (fontes confiГғВЎveis)
            const examples = [];
            const exampleDivs = doc.querySelectorAll('.example');
            
            exampleDivs.forEach((div) => {
                const enText = div.querySelector('.tag_s')?.textContent?.trim();
                const ptText = div.querySelector('.tag_t')?.textContent?.trim();
                const source = div.querySelector('.source')?.textContent?.trim() || 'Verificado';
                
                if (enText && ptText) {
                    examples.push({ 
                        en: enText, 
                        pt: ptText,
                        source: source,
                        verified: true
                    });
                }
            });
            
            // NOVO: Extrai exemplos NГғЖ’O VERIFICADOS (fontes externas - MUITO MAIS exemplos!)
            const unverifiedDivs = doc.querySelectorAll('.inexact, .unverified, .translation_group');
            
            unverifiedDivs.forEach((div) => {
                const enText = div.querySelector('.tag_s, .source_text, .left')?.textContent?.trim();
                const ptText = div.querySelector('.tag_t, .target_text, .right')?.textContent?.trim();
                const source = div.querySelector('.source')?.textContent?.trim() || 'NГғВЈo verificado';
                
                if (enText && ptText && enText.length > 5 && ptText.length > 5) {
                    const isDuplicate = examples.some(ex => 
                        ex.en.toLowerCase() === enText.toLowerCase() || 
                        ex.pt.toLowerCase() === ptText.toLowerCase()
                    );
                    
                    if (!isDuplicate) {
                        examples.push({ 
                            en: enText, 
                            pt: ptText,
                            source: source,
                            verified: false
                        });
                    }
                }
            });
            
            // NOVO: Busca AGRESSIVA em TODAS as divs que contenham texto bilГғВӯngue
            const allTextDivs = doc.querySelectorAll('div[class*="example"], div[class*="translation"], div[class*="lemma"]');
            
            allTextDivs.forEach((div) => {
                const spans = div.querySelectorAll('span');
                if (spans.length >= 2) {
                    const enText = spans[0]?.textContent?.trim();
                    const ptText = spans[1]?.textContent?.trim();
                    
                    if (enText && ptText && enText.length > 10 && ptText.length > 10) {
                        const isDuplicate = examples.some(ex => 
                            ex.en.toLowerCase() === enText.toLowerCase() || 
                            ex.pt.toLowerCase() === ptText.toLowerCase()
                        );
                        
                        if (!isDuplicate) {
                            examples.push({ 
                                en: enText, 
                                pt: ptText,
                                source: 'Linguee',
                                verified: false
                            });
                        }
                    }
                }
            });
            
            // NOVO: Busca em tabelas de traduГғВ§ГғВЈo
            const translationTables = doc.querySelectorAll('table.translation_table, .translation_lines');
            translationTables.forEach((table) => {
                const rows = table.querySelectorAll('tr, .translation_line');
                rows.forEach((row) => {
                    const cells = row.querySelectorAll('td, .source, .target');
                    if (cells.length >= 2) {
                        const enText = cells[0]?.textContent?.trim();
                        const ptText = cells[1]?.textContent?.trim();
                        
                        if (enText && ptText && enText.length > 10 && ptText.length > 10) {
                            const isDuplicate = examples.some(ex => 
                                ex.en.toLowerCase() === enText.toLowerCase()
                            );
                            
                            if (!isDuplicate) {
                                examples.push({ 
                                    en: enText, 
                                    pt: ptText,
                                    source: 'Linguee',
                                    verified: false
                                });
                            }
                        }
                    }
                });
            });
            
            console.log(`[LinguaFlow Dashboard] Exemplos encontrados: ${examples.length} (${examples.filter(e => e.verified).length} verificados, ${examples.filter(e => !e.verified).length} nГғВЈo verificados)`);
            
            if (examples.length === 0) {
                panel.innerHTML = '<p style="color:#94A3B8;">Nenhum exemplo encontrado. <a href="https://www.linguee.com.br/ingles-portugues/search?source=auto&query=' + word + '" target="_blank" style="color:#38BDF8;">Ver no Linguee ГўвҖ вҖ”</a></p>';
                return;
            }
            
            // No dashboard, mostra ATГғвҖ° 50 exemplos (muito mais que no popup)
            const limitedExamples = examples.slice(0, 50);
            
            panel.innerHTML = `
                <div style="margin-bottom:16px;padding:12px;background:rgba(56,189,248,0.1);border-radius:8px;border:1px solid rgba(56,189,248,0.2);">
                    <p style="margin:0;font-size:13px;color:#38BDF8;">
                        ГўЕ“вҖҰ <strong>${examples.filter(e => e.verified).length}</strong> exemplos verificados
                        ${examples.filter(e => !e.verified).length > 0 ? `<br>Г°ЕёвҖңВқ <strong>${examples.filter(e => !e.verified).length}</strong> exemplos nГғВЈo verificados (fontes externas)` : ''}
                        <br><span style="color:#94A3B8;">Total: ${examples.length} exemplos encontrados</span>
                    </p>
                </div>
                <ol class="example-list" style="max-height:500px;overflow-y:auto;">
                    ${limitedExamples.map((ex, idx) => `
                        <li style="margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,0.05);">
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                <span style="font-size:11px;color:${ex.verified ? '#10B981' : '#94A3B8'};font-weight:600;">
                                    ${ex.verified ? 'ГўЕ“вҖң VERIFICADO' : 'Г°ЕёвҖңВқ NГғЖ’O VERIFICADO'}
                                </span>
                            </div>
                            <span class="ex-en" style="display:block;margin-bottom:6px;font-size:14px;line-height:1.6;">${ex.en}</span>
                            <span class="ex-pt" style="display:block;color:#10B981;font-size:13px;line-height:1.6;">${ex.pt}</span>
                        </li>
                    `).join('')}
                </ol>
                <div style="margin-top:16px;text-align:center;">
                    ${examples.length > 50 ? `<p style="color:#94A3B8;margin-bottom:12px;">Mostrando 50 de ${examples.length} exemplos</p>` : ''}
                    <a href="https://www.linguee.com.br/ingles-portugues/search?source=auto&query=${word}" target="_blank" class="btn-action btn-blue" style="display:inline-block;text-decoration:none;">Ver todos no Linguee ГўвҖ вҖ”</a>
                </div>
            `;
        } catch (err) {
            console.error('[LinguaFlow Dashboard] Erro ao buscar exemplos:', err);
            panel.innerHTML = '<p style="color:#EF4444;">Erro ao buscar exemplos. <a href="https://www.linguee.com.br/ingles-portugues/search?source=auto&query=' + word + '" target="_blank" style="color:#38BDF8;">Abrir Linguee ГўвҖ вҖ”</a></p>';
        }
    }
    
    loadModalGramatica(word) {
        const panel = document.getElementById('panel-gramatica');
        
        const grammarInfo = {
            'noun': {
                title: 'SUBSTANTIVO',
                desc: 'Palavra que nomeia pessoas, lugares, coisas ou ideias.',
                tips: ['Pode ser singular ou plural', 'Pode ser contГғВЎvel ou incontГғВЎvel']
            },
            'verb': {
                title: 'VERBO',
                desc: 'Palavra que expressa aГғВ§ГғВЈo, estado ou ocorrГғВӘncia.',
                tips: ['Pode ser regular ou irregular', 'Muda de forma conforme o tempo verbal']
            },
            'adjective': {
                title: 'ADJETIVO',
                desc: 'Palavra que descreve ou modifica um substantivo.',
                tips: ['Geralmente vem antes do substantivo em inglГғВӘs', 'Pode ter formas comparativas']
            }
        };
        
        const pos = word.part_of_speech?.toLowerCase() || 'word';
        const info = grammarInfo[pos] || {
            title: pos.toUpperCase(),
            desc: 'InformaГғВ§ГғВЈo gramatical nГғВЈo disponГғВӯvel.',
            tips: []
        };
        
        let html = `
            <div class="grammar-section">
                <h4>${info.title}</h4>
                <p>${info.desc}</p>
            </div>
        `;
        
        if (info.tips.length > 0) {
            html += '<div class="grammar-section"><h4>DICAS</h4>';
            info.tips.forEach(tip => {
                html += `<span class="grammar-tag">${tip}</span>`;
            });
            html += '</div>';
        }
        
        html += `
            <div style="margin-top:16px;">
                <a href="https://youglish.com/pronounce/${word.word}/english?" target="_blank" class="btn-action btn-green" style="display:inline-block;text-decoration:none;">Ver pronГғВәncia no YouGlish ГўвҖ вҖ”</a>
            </div>
        `;
        
        panel.innerHTML = html;
    }
    
    loadModalLinguee(word) {
        const panel = document.getElementById('panel-linguee');
        panel.innerHTML = `
            <p style="margin-bottom:16px;">Veja traduГғВ§ГғВөes e exemplos completos no Linguee:</p>
            <iframe src="https://www.linguee.com.br/portugues-ingles/search?source=auto&query=${word}" style="width:100%;height:400px;border:1px solid rgba(255,255,255,0.1);border-radius:8px;"></iframe>
        `;
    }
    
    async deleteWord(wordId) {
        if (!confirm('Tem certeza que deseja deletar esta palavra?')) return;
        
        try {
            const db = await openDB();
            const tx = db.transaction(['words', 'cards'], 'readwrite');
            const wordsStore = tx.objectStore('words');
            const cardsStore = tx.objectStore('cards');
            
            // Busca palavra
            const wordReq = wordsStore.get(wordId);
            
            wordReq.onsuccess = () => {
                const word = wordReq.result;
                if (word) {
                    // Deleta card associado
                    const cardReq = cardsStore.index('word_id').get(wordId);
                    cardReq.onsuccess = () => {
                        if (cardReq.result) {
                            cardsStore.delete(cardReq.result.id);
                        }
                        // Deleta palavra
                        wordsStore.delete(wordId);
                        
                        // Recarrega vocabulГғВЎrio
                        this.loadVocab();
                    };
                }
            };
        } catch (e) {
            console.error('Erro ao deletar palavra:', e);
        }
    }
    
    async loadSettingsUI() {
        const settings = await loadSettings();
        
        document.getElementById('srs-new-per-day').value = settings.newPerDay;
        document.getElementById('srs-reviews-per-day').value = settings.reviewsPerDay;
        document.getElementById('srs-learning-steps').value = settings.learningSteps.join(' ');
        document.getElementById('srs-graduating-interval').value = settings.graduatingInterval;
        document.getElementById('srs-easy-interval').value = settings.easyInterval;
        document.getElementById('srs-starting-ease').value = settings.startingEase;
        document.getElementById('srs-easy-bonus').value = settings.easyBonus;
        document.getElementById('srs-interval-modifier').value = settings.intervalModifier;
        document.getElementById('srs-lapse-steps').value = settings.lapseSteps.join(' ');
        document.getElementById('srs-min-interval').value = settings.minInterval;
        document.getElementById('srs-lapse-penalty').value = settings.lapsePenalty * 100;
        document.getElementById('srs-new-order').value = settings.newOrder;
        document.getElementById('srs-show-ipa').checked = settings.showIPA;
        document.getElementById('srs-show-context').checked = settings.showContext;
        document.getElementById('srs-auto-audio').checked = settings.autoAudio;
        document.getElementById('srs-native-lang').value = settings.nativeLang;
        document.getElementById('srs-target-lang').value = settings.targetLang;
    }
    
    async saveSettings() {
        const settings = {
            newPerDay: parseInt(document.getElementById('srs-new-per-day').value) || 20,
            reviewsPerDay: parseInt(document.getElementById('srs-reviews-per-day').value) || 100,
            learningSteps: document.getElementById('srs-learning-steps').value.split(' ').map(Number).filter(n => n > 0),
            graduatingInterval: parseInt(document.getElementById('srs-graduating-interval').value) || 1,
            easyInterval: parseInt(document.getElementById('srs-easy-interval').value) || 4,
            startingEase: parseFloat(document.getElementById('srs-starting-ease').value) || 2.5,
            easyBonus: parseFloat(document.getElementById('srs-easy-bonus').value) || 1.3,
            intervalModifier: parseFloat(document.getElementById('srs-interval-modifier').value) || 1.0,
            lapseSteps: document.getElementById('srs-lapse-steps').value.split(' ').map(Number).filter(n => n > 0),
            minInterval: parseInt(document.getElementById('srs-min-interval').value) || 1,
            lapsePenalty: parseFloat(document.getElementById('srs-lapse-penalty').value) / 100 || 0.2,
            newOrder: document.getElementById('srs-new-order').value,
            showIPA: document.getElementById('srs-show-ipa').checked,
            showContext: document.getElementById('srs-show-context').checked,
            autoAudio: document.getElementById('srs-auto-audio').checked,
            nativeLang: document.getElementById('srs-native-lang').value,
            targetLang: document.getElementById('srs-target-lang').value
        };
        
        await saveSettings(settings);
        alert('ConfiguraГғВ§ГғВөes salvas com sucesso!');
    }
    
    async resetSettings() {
        if (!confirm('Tem certeza que deseja restaurar as configuraГғВ§ГғВөes padrГғВЈo?')) return;
        
        await resetSettings();
        this.loadSettingsUI();
        alert('ConfiguraГғВ§ГғВөes restauradas para o padrГғВЈo!');
    }
    
    exportData() {
        const data = {
            words: this.words,
            exportedAt: new Date().toISOString()
        };
        
        const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        
        const a = document.createElement('a');
        a.href = url;
        a.download = `linguaflow-backup-${new Date().toISOString().split('T')[0]}.json`;
        a.click();
        
        URL.revokeObjectURL(url);
    }
    
    importData() {
        document.getElementById('import-file-input').click();
    }
    
    handleImportFile(e) {
        const file = e.target.files[0];
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = (event) => {
            try {
                const data = JSON.parse(event.target.result);
                
                if (!confirm(`Tem certeza que deseja importar ${data.words?.length || 0} palavras? Isso pode sobrescrever dados existentes.`)) {
                    return;
                }
                
                this.importWords(data.words);
                alert('Dados importados com sucesso!');
            } catch (err) {
                alert('Erro ao importar dados: ' + err.message);
            }
        };
        reader.readAsText(file);
        
        // Limpa input
        e.target.value = '';
    }
    
    async importWords(words) {
        if (!words || !Array.isArray(words)) return;
        
        try {
            const db = await openDB();
            const tx = db.transaction(['words', 'cards'], 'readwrite');
            const wordsStore = tx.objectStore('words');
            const cardsStore = tx.objectStore('cards');
            
            let imported = 0;
            
            for (const word of words) {
                // Verifica se jГғВЎ existe
                const index = wordsStore.index('word_lang');
                const checkReq = index.get([word.word, word.lang || 'en']);
                
                checkReq.onsuccess = () => {
                    if (!checkReq.result) {
                        // Nova palavra
                        const wordReq = wordsStore.put({
                            ...word,
                            id: undefined,
                            added_at: word.added_at || Date.now()
                        });
                        
                        wordReq.onsuccess = () => {
                            // Cria card
                            const card = {
                                word_id: wordReq.result,
                                interval: 0,
                                ease_factor: 2.5,
                                due_date: Date.now(),
                                reps: 0,
                                lapses: 0,
                                status: 'new'
                            };
                            cardsStore.put(card);
                            imported++;
                        };
                    }
                };
            }
            
            // Recarrega vocabulГғВЎrio
            setTimeout(() => {
                this.loadVocab();
            }, 1000);
        } catch (e) {
            console.error('Erro ao importar palavras:', e);
        }
    }
    
    exportToAnki() {
        const ankiCards = this.words.map(word => ({
            word: word.word,
            translation: word.translation,
            context: word.context_sentence,
            ipa: word.ipa,
            pos: word.part_of_speech
        }));
        
        const csv = 'word,translation,context,ipa,pos\n' + ankiCards.map(c => 
            `"${c.word}","${c.translation}","${c.context}","${c.ipa}","${c.pos}"`
        ).join('\n');
        
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        
        const a = document.createElement('a');
        a.href = url;
        a.download = `linguaflow-anki-${new Date().toISOString().split('T')[0]}.csv`;
        a.click();
        
        URL.revokeObjectURL(url);
    }
    
}

// Inicializa dashboard
const dashboard = new Dashboard();

// Atualiza badge quando palavra ГғВ© salva
window.addEventListener('LF_WORD_SAVED', (e) => {
    console.log('[LinguaFlow Dashboard] Evento LF_WORD_SAVED recebido:', e.detail);
    dashboard.loadStats();
});

// Atualiza vocabulГғВЎrio quando palavra ГғВ© salva
window.addEventListener('LF_WORD_SAVED', (e) => {
    console.log('[LinguaFlow Dashboard] Evento LF_WORD_SAVED (vocab) recebido:', e.detail);
    if (dashboard.currentTab === 'vocab') {
        dashboard.loadVocab();
    }
});

// Atualiza badge quando palavra ГғВ© marcada como conhecida
window.addEventListener('LF_WORD_KNOWN', () => {
    dashboard.loadStats();
});

// Escuta mensagens do background
chrome.runtime.onMessage.addListener((request) => {
    console.log('[LinguaFlow Dashboard] Mensagem recebida:', request.type);
    
    if (request.type === 'REFRESH_VOCAB') {
        console.log('[LinguaFlow Dashboard] Atualizando vocabulГғВЎrio (REFRESH_VOCAB)...');
        if (dashboard.currentTab === 'vocab') {
            dashboard.loadVocab();
        }
        dashboard.loadStats();
    }
    
    if (request.type === 'REFRESH_DASHBOARD') {
        console.log('[LinguaFlow Dashboard] Atualizando dashboard (REFRESH_DASHBOARD)...');
        console.log('[LinguaFlow Dashboard] Palavra salva:', request.word, 'ID:', request.id);
        
        // ForГғВ§a atualizaГғВ§ГғВЈo imediata
        dashboard.loadVocab();
        dashboard.loadStats();
        
        // Se estiver na aba de revisГғВЈo, recarrega tambГғВ©m
        if (dashboard.currentTab === 'review') {
            dashboard.loadReview();
        }
    }
});

