{
  "buildCommand": null,
  "installCommand": null,
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), geolocation=(), microphone=(self)" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/dashboard/css/$1" },
    { "source": "/js/(.*)", "destination": "/dashboard/js/$1" },
    { "source": "/assets/(.*)", "destination": "/dashboard/assets/$1" },
    { "source": "/icons/(.*)", "destination": "/dashboard/icons/$1" },
    { "source": "/sw.js", "destination": "/dashboard/sw.js" },
    { "source": "/manifest.webmanifest", "destination": "/dashboard/manifest.webmanifest" },
    { "source": "/:route(login|home|library|study|leagues|settings|game|stories|reader|stats|learn|progress)/css/(.*)", "destination": "/dashboard/css/$2" },
    { "source": "/:route(login|home|library|study|leagues|settings|game|stories|reader|stats|learn|progress)/js/(.*)", "destination": "/dashboard/js/$2" },
    { "source": "/:route(login|home|library|study|leagues|settings|game|stories|reader|stats|learn|progress)/assets/(.*)", "destination": "/dashboard/assets/$2" },
    { "source": "/:route(login|home|library|study|leagues|settings|game|stories|reader|stats|learn|progress)/icons/(.*)", "destination": "/dashboard/icons/$2" },
    { "source": "/:route(login|home|library|study|leagues|settings|game|stories|reader|stats|learn|progress)/utils/(.*)", "destination": "/utils/$2" },
    { "source": "/", "destination": "/dashboard/dashboard.html" },
    { "source": "/(login|home|library|study|leagues|settings|game|stories|reader|stats|learn|progress)", "destination": "/dashboard/dashboard.html" }
  ]
}
